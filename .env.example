# Copia este archivo como .env y completa tus propios valores.
# .env NO debe subirse nunca al repositorio (ya está en .gitignore).

# Token de autenticación de ngrok (https://dashboard.ngrok.com/get-started/your-authtoken)
NGROK_AUTHTOKEN=tu_token_aqui

# Opcional: ruta al ejecutable de tesseract si no está en el PATH del sistema.
# Ejemplo Windows: C:\Program Files\Tesseract-OCR\tesseract.exe
# Ejemplo Linux/Mac: normalmente no hace falta si se instaló con el gestor de paquetes.
TESSERACT_CMD=
